{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Register checklist items for each build. Noober tracks pass\/fail status per build number and auto-resets when a new build is detected.","type":"text"}]},{"anchor":"Registering-Items","type":"heading","level":3,"text":"Registering Items"},{"code":["Noober.shared.registerChecklist([","    .init(\"Login flow\",","          notes: \"Test with email + social login\",","          priority: .high,","          endpoints: [\"\/auth\/login\", \"\/auth\/social\"]),","    .init(\"Checkout\",","          notes: \"Test with & without saved cards\",","          priority: .high,","          endpoints: [\"\/api\/payments\"]),","    .init(\"Pull-to-refresh on feed\",","          priority: .normal),","    .init(\"Dark mode rendering\",","          priority: .low),","])"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Parameters","anchor":"Parameters"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"title","type":"text"}],"type":"strong"},{"type":"text","text":" — what to test"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"notes","type":"text"}],"type":"strong"},{"type":"text","text":" — additional context or instructions"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"priority","type":"text"}]},{"type":"text","text":" — "},{"type":"codeVoice","code":".high"},{"text":", ","type":"text"},{"code":".normal","type":"codeVoice"},{"text":", or ","type":"text"},{"code":".low","type":"codeVoice"},{"text":" (affects sort order)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"endpoints"}],"type":"strong"},{"type":"text","text":" — associated API endpoints (helps connect failures to network requests)"}],"type":"paragraph"}]}]},{"level":3,"type":"heading","text":"Tracking Results","anchor":"Tracking-Results"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the QA tab of the debug panel:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Pass"}],"type":"strong"},{"type":"text","text":" — mark an item as tested and working"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Fail"}],"type":"strong"},{"type":"text","text":" — mark as failed with notes and optionally attach captured network requests"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Reset"}],"type":"strong"},{"type":"text","text":" — return an item to pending status"}],"type":"paragraph"}]}]},{"level":3,"type":"heading","text":"Build Awareness","anchor":"Build-Awareness"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Checklist state is keyed by the app’s build number ("},{"type":"codeVoice","code":"CFBundleVersion"},{"type":"text","text":"). When Noober detects a new build number, it resets all statuses to pending while preserving the item definitions from "},{"type":"codeVoice","code":"registerChecklist(_:)"},{"type":"text","text":"."}]}]}],"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Track QA testing progress with a build-aware checklist."}],"seeAlsoSections":[{"title":"Essentials","generated":true,"identifiers":["doc:\/\/noober.Noober\/documentation\/Noober\/GettingStarted","doc:\/\/noober.Noober\/documentation\/Noober\/NetworkInspector","doc:\/\/noober.Noober\/documentation\/Noober\/RulesEngine","doc:\/\/noober.Noober\/documentation\/Noober\/EnvironmentSwitching","doc:\/\/noober.Noober\/documentation\/Noober\/CustomLogging","doc:\/\/noober.Noober\/documentation\/Noober\/StorageInspector"],"anchor":"Essentials"}],"metadata":{"roleHeading":"Article","title":"QA Checklist","ro