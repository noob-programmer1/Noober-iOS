{"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register named environments with base URLs. Noober rewrites matching network requests to the active environment’s base URL automatically."}]},{"level":3,"type":"heading","anchor":"Registering-Environments","text":"Registering Environments"},{"type":"codeListing","syntax":"swift","code":["Noober.shared.registerEnvironments([","    .init(name: \"Production\", baseURL: \"https:\/\/api.example.com\"),","    .init(name: \"Staging\",","          baseURL: \"https:\/\/api.staging.example.com\",","          notes: \"Uses test payment keys\"),","    .init(name: \"Local\",","          baseURL: \"http:\/\/localhost:8080\"),","])"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first environment is the default (no URL rewriting). Selecting any other environment rewrites the scheme, host, and port of matching requests while preserving the path, query, and fragment."}]},{"level":3,"type":"heading","anchor":"Multi-URL-Environments","text":"Multi-URL Environments"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your app talks to multiple servers, use positional base URL mapping:"}]},{"type":"codeListing","syntax":"swift","code":["Noober.shared.registerEnvironments([","    .init(name: \"Production\",","          baseURLs: [\"https:\/\/api.example.com\", \"https:\/\/cdn.example.com\"]),","    .init(name: \"Staging\",","          baseURLs: [\"https:\/\/api.staging.example.com\", \"https:\/\/cdn.staging.example.com\"]),","])"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Requests matching "},{"code":"baseURLs[0]","type":"codeVoice"},{"type":"text","text":" of the default environment are rewritten to "},{"code":"baseURLs[0]","type":"codeVoice"},{"type":"text","text":" of the active environment, and so on."}]},{"level":3,"type":"heading","anchor":"Persistence","text":"Persistence"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The active environment selection is saved to UserDefaults and restored on the next launch."}]}]}],"abstract":[{"type":"text","text":"Switch between server environments with one tap."}],"hierarchy":{"paths":[["doc:\/\/noober.Noober\/documentation\/Noober"]]},"metadata":{"title":"Environment Switching","roleHeading":"Article","role":"article","modules":[{"name":"Noober"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/noober\/environmentswitching"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/noober.Noober\/documentation\/Noober\/EnvironmentSwitching"},"seeAlsoSections":[{"title":"Essentials","generated":true,"identifiers":["doc:\/\/noober.Noober\/documentation\/Noober\/GettingStarted","doc:\/\/noober.Noober\/documentation\/Noober\/NetworkInspector","doc:\/\/noober.Noober\/documentation\/Noober\/RulesEngine","doc:\/\/noober.Noober\/documentation\/Noober\/CustomLogging","doc:\/\/noober.Noober\/documentation\/Noober\/StorageInspector","doc:\/\/noober.Noober\/documentation\/Noober\/QAChecklist"],"anchor":"Essentials"}],"sections":[],"references":{"doc://noober.Noober/documentation/Noober/StorageInspector":{"url":"\/documentation\/noober\/storageinspector","role":"article","kind":"article","title":"Storage Inspector","abstract":[{"text":"Browse and edit UserDefaults and Keychain entries.","type":"text"}],"type":"topic","identifier":"doc:\/\/noober.Noober\/documentation\/Noober\/StorageInspector"},"doc://noober.Noober/documentation/Noober":{"title":"Noober","abstract":[{"type":"text","text":"A powerful, zero-dependency debugging toolkit for iOS apps."}],"kind":"symbol","identifier":"doc:\/\/noober.Noober\/documentation\/Noober","type":"topic","url":"\/documentation\/noober","role":"collection"},"doc://noober.Noober/documentation/Noober/CustomLogging":{"title":"Custom Logging","ab