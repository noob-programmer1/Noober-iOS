{"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Noober provides a complete suite of debugging tools that integrate into your iOS app via a floating overlay bubble. Tap the bubble to open a full-featured debug panel with five tabs: Network, Storage, Logs, Rules, and QA.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"All ","type":"text"},{"code":"URLSession","type":"codeVoice"},{"text":" network traffic is captured automatically — no manual instrumentation required. WebSocket connections are also monitored. The rules engine lets you rewrite URLs, mock responses, and intercept requests mid-flight for editing. Environment switching lets your team toggle between servers with one tap.","type":"text"}]},{"level":3,"type":"heading","text":"Quick Start","anchor":"Quick-Start"},{"syntax":"swift","type":"codeListing","code":["#if DEBUG","import Noober","","Noober.shared.start()","#endif"]},{"type":"paragraph","inlineContent":[{"text":"That’s it. A floating bubble appears on screen. Tap it to open the debug panel.","type":"text"}]},{"name":"Warning","type":"aside","style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Noober is designed for debugging only. Always wrap usage with "},{"code":"#if DEBUG","type":"codeVoice"},{"type":"text","text":" to exclude it from release builds."}]}]}],"kind":"content"}],"abstract":[{"type":"text","text":"A powerful, zero-dependency debugging toolkit for iOS apps."}],"metadata":{"modules":[{"name":"Noober"}],"role":"collection","symbolKind":"module","roleHeading":"Framework","title":"Noober","externalID":"Noober"},"hierarchy":{"paths":[[]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/noober"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"anchor":"Essentials","identifiers":["doc:\/\/noober.Noober\/documentation\/Noober\/GettingStarted